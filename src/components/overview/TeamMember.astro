---
interface Props {
  name: string;
  role: string;
  tagline: string;
  imageSrc: string;
}

const { name, role, tagline, imageSrc } = Astro.props;
---

<div class="team-member">
  <div class="photo-wrapper">
    <img src={imageSrc} alt={`${name} - ${role}`} class="team-photo" loading="lazy" />
  </div>
  <h3 class="member-name">{name}</h3>
  <p class="member-role">{role}</p>
  <p class="member-tagline">{tagline}</p>
</div>

<style>
  .team-member {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-lg);
  }

  .photo-wrapper {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--color-border);
    margin-bottom: var(--space-md);
    transition: border-color 0.3s ease;
  }

  .team-member:hover .photo-wrapper {
    border-color: var(--color-accent);
  }

  .team-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .member-name {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 2px;
  }

  .member-role {
    font-size: 0.9rem;
    color: var(--color-accent);
    font-weight: 500;
    margin-bottom: var(--space-sm);
  }

  .member-tagline {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-style: italic;
    max-width: 220px;
  }

  @media (max-width: 768px) {
    .photo-wrapper {
      width: 140px;
      height: 140px;
    }
  }
</style>
