---
import { social } from '../../data/social';
---

<section class="bio section">
  <h1 class="bio-name">Rutkay</h1>
  <p class="bio-tagline">Coding mobile apps, writing blog posts, getting excited about AI</p>
  <p class="bio-location">Germany</p>
  <p class="bio-description">
    Indie developer building mobile apps with Flutter and experimenting with AI-powered workflows.
    I write about what I learn and build tools that make development more fun.
  </p>
  <div class="bio-links">
    <a href={social.github} target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href={social.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
    <a href={social.medium} target="_blank" rel="noopener noreferrer">Medium</a>
  </div>
</section>

<style>
  .bio {
    text-align: center;
  }

  .bio-name {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-sm);
  }

  .bio-tagline {
    color: var(--color-text-secondary);
    font-size: 1.1rem;
    margin-bottom: var(--space-xs);
  }

  .bio-location {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: var(--space-lg);
  }

  .bio-description {
    max-width: 560px;
    margin: 0 auto var(--space-lg);
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .bio-links {
    display: flex;
    justify-content: center;
    gap: var(--space-lg);
  }

  .bio-links a {
    font-weight: 500;
    font-size: 0.95rem;
  }

  @media (max-width: 768px) {
    .bio-name {
      font-size: 2rem;
    }
  }
</style>
