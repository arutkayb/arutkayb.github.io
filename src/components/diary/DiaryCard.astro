---
interface Props {
  id: string;
  date: Date;
  stats?: string;
  overview: string;
}

const { id, date, stats, overview } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/diary/${id}/`} class="diary-card">
  <div class="diary-header">
    <span class="diary-date">{formattedDate}</span>
  </div>
  {stats && <h3 class="diary-title">{stats}</h3>}
  <p class="diary-overview">{overview}</p>
</a>

<style>
  .diary-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-md);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    transition: transform 0.2s ease, border-color 0.2s ease;
    color: inherit;
  }

  .diary-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-accent);
  }

  .diary-header {
    display: flex;
    justify-content: flex-end;
  }

  .diary-date {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .diary-title {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-accent);
    line-height: 1.4;
  }

  .diary-overview {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 7;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
