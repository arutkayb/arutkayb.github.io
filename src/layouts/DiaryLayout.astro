---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  stats?: string;
}

const { title, date, stats } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} - Rutkay`}>
  <article class="diary-entry section">
    <header class="diary-header">
      <a href="/diary/" class="back-link">&larr; Back to Diary</a>
      <h1 class="diary-title">{title}</h1>
      <time class="diary-date">{formattedDate}</time>
      {stats && <p class="diary-stats">{stats}</p>}
    </header>
    <div class="diary-content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .diary-header {
    margin-bottom: var(--space-xl);
  }

  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .diary-title {
    font-size: 1.75rem;
    margin-bottom: var(--space-sm);
  }

  .diary-date {
    display: block;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    margin-bottom: var(--space-sm);
  }

  .diary-stats {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-accent);
  }

  .diary-content :global(h2) {
    font-size: 1.3rem;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
    color: var(--color-text-primary);
  }

  .diary-content :global(h3) {
    font-size: 1.1rem;
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .diary-content :global(p) {
    margin-bottom: var(--space-md);
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .diary-content :global(ul),
  .diary-content :global(ol) {
    margin-bottom: var(--space-md);
    padding-left: var(--space-lg);
    color: var(--color-text-secondary);
  }

  .diary-content :global(li) {
    margin-bottom: var(--space-sm);
    line-height: 1.6;
  }

  .diary-content :global(strong) {
    color: var(--color-text-primary);
  }

  .diary-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-md);
    margin: var(--space-lg) 0;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .diary-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-xl) 0;
  }
</style>
